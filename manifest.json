{
  "required_api_version": "^2.0.0",
  "name": "2FA",
  "description": "2FA Authentication Extension",
  "developer_name": "Silvan S. Batistella",
  "icon": "images/icon.png",
  "options": {
    "query_debounce": 0.1
  },
  "preferences": [
    {
      "id": "tfa_kw",
      "type": "keyword",
      "name": "2FA",
      "description": "Generate 2FA authentication code",
      "default_value": "2fa"
    },
    {
      "id": "tfa_providers",
      "type": "text",
      "name": "Services",
      "description": "key=value records separated by semicolon (;): <key1>=<value1>;<key2>=<value2>"
    },
    {
      "id": "tfa_max_providers",
      "type": "text",
      "name": "Number of Services",
      "description": "Number of services to display",
      "default_value": "10"
    }
  ]
}
